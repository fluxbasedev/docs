{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Fluxbase Documentation",
  "colors": {
    "primary": "#4541D9",
    "light": "#4541D9",
    "dark": "#4541D9"
  },
  "favicon": "/favicon.svg",
  "api": {
    "openapi": "https://api.fluxbase.dev/openapi.json"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "/pages/getting-started/index",
              "/pages/getting-started/changelog",
              "/pages/getting-started/listing-first-bot",
              "/pages/getting-started/verification-process"
            ]
          },
          {
            "group": "API",
            "pages": [
              "/pages/api/authentication",
              "/pages/api/error-codes-responses",
              "/pages/api/pagination",
              "/pages/api/rate-limiting"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "https://api.fluxbase.dev/openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Fluxbase",
          "href": "https://fluxbase.dev",
          "icon": {
            "name": "home",
            "style": "duotone"
          }
        },
        {
          "anchor": "Fluxer Community",
          "href": "https://fluxer.gg/fluxbase",
          "icon": {
            "name": "external-link",
            "style": "duotone"
          }
        },
        {
          "anchor": "Contact",
          "href": "mailto:contact@fluxbase.dev",
          "icon": {
            "name": "at",
            "style": "duotone"
          }
        },
        {
          "anchor": "Donate",
          "href": "https://github.com/sponsors/fluxbasedev",
          "icon": {
            "name": "heart",
            "style": "duotone"
          }
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/fluxbasedev"
    }
  }
}
